# ── App ───────────────────────────────────────────────────────────────
APP_NAME=SyllaCheck
APP_ENV=development           # development | production
SECRET_KEY=change-me-to-a-long-random-string-in-production
DEBUG=true

# ── Database ──────────────────────────────────────────────────────────
POSTGRES_DB=syllacheck
POSTGRES_USER=syllacheck
POSTGRES_PASSWORD=devpassword
DATABASE_URL=postgresql+asyncpg://syllacheck:devpassword@db:5432/syllacheck

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Auth (JWT) ────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── OpenAI ────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o

# ── File Upload ───────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=20
ALLOWED_EXTENSIONS=pdf,docx,doc

# ── Reports (Phase 7) ─────────────────────────────────────────────────
# Directory where generated PDF and Excel reports are stored inside the container
REPORT_DIR=/app/reports

# ── Google OAuth (Phase 7) ────────────────────────────────────────────
# Get these from: https://console.cloud.google.com
#   APIs & Services → Credentials → Create OAuth 2.0 Client ID → Web application
#   Authorized redirect URIs:
#     Dev:  http://localhost/api/auth/google/callback
#     Prod: https://yourdomain.com/api/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:5173/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# The URL your frontend is served from (used to redirect after Google login)
FRONTEND_URL=http://localhost:5173

# ── Scraping ──────────────────────────────────────────────────────────
SCRAPE_INTERVAL_HOURS=24
MAX_JOBS_PER_SOURCE=500
PLAYWRIGHT_HEADLESS=true

# ── CORS ──────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost
